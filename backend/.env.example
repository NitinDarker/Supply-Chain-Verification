# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/velen

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=super-secret-key
JWT_EXPIRES_IN=24h

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASS=gmail-app-password

# OTP
OTP_EXPIRY_SECONDS=300

# Wallet Encryption
WALLET_ENCRYPTION_KEY=32-char-encryption-key
